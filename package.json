{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @portfolio/web --filter @portfolio/api-profile --filter @portfolio/api-site dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:db:profile": "pnpm --filter @portfolio/shared-types test:db:profile",
    "test:db:site": "pnpm --filter @portfolio/shared-types test:db:site",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
