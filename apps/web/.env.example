# Base URL of the profile/CV API (apps/api-profile)
NEXT_PUBLIC_PROFILE_API_URL=http://localhost:3001

# Base URL of the site API (apps/api-site)
NEXT_PUBLIC_SITE_API_URL=http://localhost:3002

# API key for apps/api-profile (sent as X-API-Key, server-side only — must
# NOT be prefixed NEXT_PUBLIC_ and must never reach the browser bundle).
# Mint with `pnpm --filter @portfolio/api-profile create-api-key`.
PROFILE_API_KEY=
