# Apex domain (Route53 hosted zone), e.g. "example.com"
DOMAIN_NAME=

# Route53 hosted zone ID for DOMAIN_NAME
HOSTED_ZONE_ID=

# Subdomains for each API (defaults shown)
PROFILE_API_SUBDOMAIN=api
SITE_API_SUBDOMAIN=site-api

# ARNs of Secrets Manager secrets, each with JSON keys { "url": "...", "serviceRoleKey": "..." }.
# These MUST be two separate secrets — the profile and site Supabase projects'
# service_role keys must never be shared.
PROFILE_SUPABASE_SECRET_ARN=
SITE_SUPABASE_SECRET_ARN=

# CORS allow-lists (comma-separated). apps/api-profile relies primarily on
# its own API-key auth but still restricts CORS as defense-in-depth;
# apps/api-site must be restricted to the production apps/web origin(s).
PROFILE_ALLOWED_ORIGINS=
SITE_ALLOWED_ORIGINS=

# API Gateway stage throttling (requests/sec), applied as a backstop on top
# of each API's own application-level rate limiting (100/min).
API_THROTTLE_RATE_LIMIT=100
API_THROTTLE_BURST_LIMIT=50

# CloudWatch log retention in days (one of: 14, 30, 90, 365; default 30)
LOG_RETENTION_DAYS=30

# Standard CDK environment pinning. If unset, stacks synth as
# environment-agnostic (fine for `cdk synth`, required for `cdk deploy`).
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=
